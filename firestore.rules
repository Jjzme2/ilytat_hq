rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // Helper Functions
    // ---------------------------------------------------------------
    
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Checks if the user is the owner of the document
    function isDocOwner(resource) {
      return isAuth() && resource.data.ownerId == request.auth.uid;
    }

    // Checks if the user is in the members array of the document
    function isMember(resource) {
      return isAuth() && resource.data.members != null && resource.data.members.hasAny([request.auth.uid]);
    }

    // Checks if the document is universal (read-only for most)
    function isUniversal(resource) {
        return resource.data.type == 'universal' || resource.data.isUniversal == true;
    }

    // Checks if the document is public
    function isPublic(resource) {
      return resource.data.access == 'public';
    }

    // Checks if the user is a super admin
    function isSuper() {
      return isAuth() && (
        (request.auth.token.keys().hasAny(['roles']) && request.auth.token.roles.toSet().hasAny(['super'])) || 
        request.auth.token.email == 'admin@ilytat.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['super'])
      );
    }

    function isAdmin() {
      return isAuth() && (
        (request.auth.token.keys().hasAny(['roles']) && request.auth.token.roles.toSet().hasAny(['admin'])) || 
        (request.auth.token.keys().hasAny(['role']) && request.auth.token.role == 'admin') ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin'])
      );
    }

    // Checks if the user has viewer role (read-only access to project data)
    function isViewer() {
      return isAuth() && (
        (request.auth.token.keys().hasAny(['roles']) && request.auth.token.roles.toSet().hasAny(['viewer'])) || 
        (request.auth.token.keys().hasAny(['role']) && request.auth.token.role == 'viewer') ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['viewer'])
      );
    }

    // ---------------------------------------------------------------
    // 1. Core Collections (Flattened)
    // ---------------------------------------------------------------

    match /ai_usage/{docId} {
      allow read: if isAuth() && (
          resource.data.userId == request.auth.uid ||
          isAdmin() || 
          isSuper()
      );
      allow write: if false; // Only server-side admin SDK can write
    }

    // Projects
    match /projects/{projectId} {
      allow read: if isMember(resource)
                  || isOwner(resource.data.ownerId) 
                  || (resource.data.ownerId == null && isOwner(resource.data.createdBy))
                  || isSuper();
      
      allow create: if isAuth(); 
      
      allow update, delete: if isOwner(resource.data.ownerId) 
                            || (resource.data.ownerId == null && isOwner(resource.data.createdBy))
                            || isSuper();
    }

    // Invitations
    match /invitations/{inviteId} {
      allow read: if resource.data.toUserId == request.auth.uid || resource.data.fromUserId == request.auth.uid || isSuper();
      allow create: if isAuth() && request.resource.data.fromUserId == request.auth.uid;
      allow update: if resource.data.toUserId == request.auth.uid || isSuper(); // Accept/Decline
      allow delete: if resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid || isSuper();
    }

    // Goals (Flattened)
    match /goals/{goalId} {
      allow read: if isOwner(resource.data.createdBy) || isSuper() || (resource.data.projectId != null && get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.members.hasAny([request.auth.uid]));
      allow create: if isAuth();
      allow update, delete: if isOwner(resource.data.createdBy) || isSuper();
    }

    // Tasks (Flattened)
    match /tasks/{taskId} {
      allow read: if isOwner(resource.data.createdBy) || request.auth.uid == resource.data.assigneeId || isSuper() || (resource.data.projectId != null && get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.members.hasAny([request.auth.uid]));
      allow create: if isAuth();
      allow update, delete: if isOwner(resource.data.createdBy) || isSuper();
    }

    // Notes (Flattened)
    match /notes/{noteId} {
      allow read: if isOwner(resource.data.createdBy) || isSuper() || (resource.data.projectId != null && get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.members.hasAny([request.auth.uid]));
      allow create: if isAuth();
      allow update, delete: if isOwner(resource.data.createdBy) || isSuper();
    }

    // Documents
    match /documents/{docId} {
      allow read: if isDocOwner(resource) || isMember(resource) || isPublic(resource) || isSuper();
      allow write: if isDocOwner(resource) || isMember(resource) || isSuper();
      allow create: if isAuth(); // Creating new docs
    }

    // Quicklinks (Flattened)
    match /quicklinks/{linkId} {
      allow read: if isDocOwner(resource) || isPublic(resource) || isSuper() || (resource.data.projectId != null && get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.members.hasAny([request.auth.uid]));
      allow create: if isAuth();
      allow update, delete: if isDocOwner(resource) || isSuper();
    }

    // Events (Schedule)
    match /events/{eventId} {
      allow read: if isOwner(resource.data.userId) || isMember(resource) || isSuper();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isMember(resource) || isSuper();
    }

    // Time Logs
    match /time_logs/{logId} {
      allow read: if isOwner(resource.data.userId) || isSuper();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isSuper();
    }

    // Quotes
    match /quotes/{quoteId} {
      allow read: if isUniversal(resource) || isDocOwner(resource) || isPublic(resource) || isSuper();
      allow write: if isDocOwner(resource) || isSuper(); // Universal quotes are managed by admins (via Admin SDK)
      allow create: if isAuth();
    }

    // User Insights
    match /user_insights/{insightId} {
      allow read: if isOwner(resource.data.userId) || isSuper();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isSuper();
    }

    // ---------------------------------------------------------------
    // 2. Users & Personal
    // ---------------------------------------------------------------
    match /users/{userId} {
      allow read: if isAuth(); 
      allow write: if isOwner(userId) || isSuper();
      
      // Keep inbox nested as it's strictly personal
      match /inbox/{msgId} {
        allow read, write: if isOwner(userId);
      }
      
      // Themes
      match /themes/{themeId} {
        allow read, write: if isOwner(userId);
      }

      // Settings (Preferences)
      match /settings/{settingId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ---------------------------------------------------------------
    // Finance (Flattened, Scoped)
    // ---------------------------------------------------------------

    // Accounts: personal (owner-only), project (financial viewers)
    match /accounts/{accountId} {
      allow read: if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        (resource.data.financialViewers != null && resource.data.financialViewers.hasAny([request.auth.uid])) ||
        isSuper()
      );
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        isSuper()
      );
      allow delete: if resource.data.ownerId == request.auth.uid || isSuper();
    }

    // Transactions: scoped to account owner
    match /transactions/{txId} {
      allow read: if isAuth() && (
        resource.data.ownerId == request.auth.uid || 
        isSuper()
      );
      allow create: if isAuth() && (
        request.resource.data.ownerId == request.auth.uid
      );
      allow update: if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        isSuper()
      );
      allow delete: if resource.data.ownerId == request.auth.uid || isSuper();
    }

    // Budgets: scoped to budget owner
    match /budgets/{budgetId} {
      allow read: if isAuth() && (
        resource.data.ownerId == request.auth.uid || isSuper()
      );
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if resource.data.ownerId == request.auth.uid || isSuper();
    }

    // ---------------------------------------------------------------
    // 3. Organizations (formerly Tenants / Guilds)
    // Reason: Users can create one organization to represent their startup.
    // Members read, owner updates, super deletes.
    // Collection stays as `tenants` for data continuity.
    // ---------------------------------------------------------------
    match /tenants/{tenantId} {
      // Any authenticated user can read their own organization
      allow read: if isAuth() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.memberIds.hasAny([request.auth.uid]) ||
        isSuper()
      );

      // Any auth user can create an organization (one per user enforced in app logic)
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;

      // Only the creator or super can update
      allow update: if isAuth() && (
        resource.data.createdBy == request.auth.uid ||
        isSuper()
      );

      // Only super can delete organizations
      allow delete: if isSuper();

      // Organization config subcollection (module enable/disable)
      match /config/{configId} {
        allow read: if isAuth() && (
          get(/databases/$(database)/documents/tenants/$(tenantId)).data.createdBy == request.auth.uid ||
          get(/databases/$(database)/documents/tenants/$(tenantId)).data.memberIds.hasAny([request.auth.uid]) ||
          isSuper()
        );
        allow write: if isAuth() && (
          get(/databases/$(database)/documents/tenants/$(tenantId)).data.createdBy == request.auth.uid ||
          isSuper()
        );
      }

      // Organization metadata subcollection (counters, etc.)
      match /metadata/{metaId} {
        allow read, write: if isAuth() && (
          get(/databases/$(database)/documents/tenants/$(tenantId)).data.createdBy == request.auth.uid ||
          isSuper()
        );
      }
    }

    // ---------------------------------------------------------------
    // 4. System & Shared
    // ---------------------------------------------------------------
    
    match /messages/{messageId} {
      allow read: if isAuth() && (
        resource.data.recipientUid == request.auth.uid || 
        resource.data.senderUid == request.auth.uid || 
        resource.data.senderId == request.auth.uid || 
        isSuper()
      );
      allow create: if isAuth() && (
        request.resource.data.senderUid == request.auth.uid ||
        request.resource.data.senderId == request.auth.uid ||
        isAdmin()
      );
      allow update: if isAuth() && (
        resource.data.recipientUid == request.auth.uid || 
        resource.data.senderUid == request.auth.uid || 
        resource.data.senderId == request.auth.uid || 
        isSuper()
      );
      allow delete: if isAuth() && (
        resource.data.senderUid == request.auth.uid || 
        resource.data.senderId == request.auth.uid || 
        isSuper()
      );
    }

    match /conversations/{conversationId} {
      allow read: if isAuth() && resource.data.participants.hasAny([request.auth.uid]);
      allow create: if isAuth() && request.resource.data.participants.hasAny([request.auth.uid]);
      allow update: if isAuth() && resource.data.participants.hasAny([request.auth.uid]);
      allow delete: if isSuper();
    }

    match /roles/{roleId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin() || isSuper();
    }

    match /permissions/{permId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin() || isSuper();
    }

    match /activity_logs/{logId} {
       allow read, write: if isAuth();
    }

    match /_lifecycle_ping/{docId} {
      allow read: if isAuth();
      allow write: if false; 
    }

    // ---------------------------------------------------------------
    // 4. Collection Groups (Recursive Wildcards)
    // ---------------------------------------------------------------
    
    match /{path=**}/tasks/{taskId} {
      allow read: if isOwner(resource.data.createdBy) || request.auth.uid == resource.data.assigneeId || isSuper() || (resource.data.projectId != null && get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.members.hasAny([request.auth.uid]));
    }

    match /{path=**}/goals/{goalId} {
      allow read: if isOwner(resource.data.createdBy) || isSuper() || (resource.data.projectId != null && get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.members.hasAny([request.auth.uid]));
    }

    match /{path=**}/projects/{projectId} {
      allow read: if isMember(resource) || isOwner(resource.data.ownerId) || isSuper();
    }

    match /{path=**}/documents/{docId} {
      allow read: if isDocOwner(resource) || isMember(resource) || isPublic(resource) || isSuper();
    }
  }
}
